# ============================================
# DeltaPress AI Provider Configuration
# ============================================
# Copy this file to .env.local and fill in your API keys
# At least one provider must be configured for AI features to work
# Only configured providers will be used - no fallback to unconfigured keys

# Anthropic Claude API Key
# Get your key at: https://console.anthropic.com/
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API Key
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Moonshot Kimi API Key
# Get your key at: https://platform.moonshot.cn/
VITE_KIMI_API_KEY=your_kimi_api_key_here

# ============================================
# Supabase Configuration (Optional)
# ============================================
# VITE_SUPABASE_URL=your_supabase_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
